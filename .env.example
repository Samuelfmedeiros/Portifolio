# Portifolio Samuel — Environment Variables

# Feature flag: Tatu Splash
# Set to "false" on production (Vercel) to skip the splash screen.
# Set to "true" (or omit) on staging/local to show the splash.
NEXT_PUBLIC_ENABLE_SPLASH=true

# Stripe — Consulting Payment Link
# Criar via Stripe Dashboard > Payment Links
# Ex: https://buy.stripe.com/3csaF73A...
NEXT_PUBLIC_STRIPE_CONSULTING_LINK=

# Stripe — Publishable Key (live)
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=

# AdSense (opcional)
NEXT_PUBLIC_ADSENSE_CLIENT_ID=
NEXT_PUBLIC_ADSENSE_SLOT_FOOTER=
NEXT_PUBLIC_ADSENSE_SLOT_SIDEBAR=

# Buy Me a Coffee (opcional — default: Samuelfmedeiros)
NEXT_PUBLIC_BMC_USERNAME=

# GitHub Sponsors (opcional)
NEXT_PUBLIC_GITHUB_SPONSORS_USERNAME=

# Umami Analytics (self-hosted)
NEXT_PUBLIC_UMAMI_URL=
NEXT_PUBLIC_UMAMI_WEBSITE_ID=
